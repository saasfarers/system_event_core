{
  "name": "Event Category Master",
  "doctype": "DocType",
  "module": "Event",
  "autoname": "field:event_category_name",
  "naming_rule": "By fieldname",
  "allow_rename": 1,
  "title_field": "event_category_name",
  "track_changes": 1,
  "fields": [
    {
      "fieldname": "naming_series",
      "fieldtype": "Select",
      "label": "Naming Series",
      "options": "ECM-.YYYY.-.####\nECM-.####"
    },
    {
      "fieldname": "event_category_name",
      "fieldtype": "Data",
      "label": "Event Category Name",
      "reqd": 1,
      "in_list_view": 1,
      "bold": 1
    },
    {
      "fieldname": "category_code",
      "fieldtype": "Data",
      "label": "Category Code",
      "in_list_view": 1
    },
    {
      "fieldname": "col_break_1",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "is_active",
      "fieldtype": "Check",
      "label": "Is Active",
      "default": "1"
    },
    {
      "fieldname": "description",
      "fieldtype": "Small Text",
      "label": "Description"
    },
    {
      "fieldname": "sec_flags",
      "fieldtype": "Section Break",
      "label": "Category Flags"
    },
    {
      "fieldname": "is_religious_event",
      "fieldtype": "Check",
      "label": "Is Religious Event?",
      "default": "0"
    },
    {
      "fieldname": "is_financial_event",
      "fieldtype": "Check",
      "label": "Is Financial Event?",
      "default": "0"
    },
    {
      "fieldname": "col_break_2",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "is_booking_enabled",
      "fieldtype": "Check",
      "label": "Is Booking Enabled?",
      "default": "0"
    },
    {
      "fieldname": "is_volunteer_enabled",
      "fieldtype": "Check",
      "label": "Is Volunteer Enabled?",
      "default": "0"
    },
    {
      "fieldname": "sec_default_components",
      "fieldtype": "Section Break",
      "label": "Default Components for this Category"
    },
    {
      "fieldname": "default_components",
      "fieldtype": "Table",
      "label": "Default Components",
      "options": "Event Category Component"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "email": 1,
      "export": 1,
      "print": 1,
      "report": 1,
      "share": 1
    }
  ]
}